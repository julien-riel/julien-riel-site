---
layout: base.njk
title: Case Studies
permalink: /en/case-studies/
lang: en
eleventyExcludeFromCollections: true
---

<section class="page">
  <header class="page-header">
    <h1 class="page-title">{{ title }}</h1>
  </header>

  <div class="section-intro">
    <p>{{ t.sections.caseStudiesIntroP1 }}</p>
    <p>{{ t.sections.caseStudiesIntroP2 }}</p>
  </div>

  {% set caselist = collections["case-studies"] | filterByLang("en") %}
  {% if caselist.length %}
  <ul class="post-list">
    {% for post in caselist | reverse %}
    <li>
      {% include "components/post-card.njk" %}
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="no-posts">No case studies yet.</p>
  {% endif %}
</section>
