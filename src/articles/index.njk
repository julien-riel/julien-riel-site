---
layout: base.njk
title: Articles techniques
description: Guides approfondis sur l'architecture des systèmes agentiques et l'ingénierie IA appliquée.
permalink: /articles/
lang: fr
eleventyExcludeFromCollections: true
---

<section class="page">
  <header class="page-header">
    <h1 class="page-title">{{ title }}</h1>
    <p class="page-description">{{ description }}</p>
  </header>

  {% set articlelist = collections["articles"] | filterByLang("fr") %}
  {% if articlelist.length %}
  <ul class="post-list">
    {% for post in articlelist | reverse %}
    <li>
      {% include "components/post-card.njk" %}
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="no-posts">Aucun article pour le moment.</p>
  {% endif %}
</section>
