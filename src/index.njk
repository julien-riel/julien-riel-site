---
layout: base.njk
title: Accueil
lang: fr
---

<section class="hero">
  <div class="hero-decoration hero-decoration--1"></div>
  <div class="hero-decoration hero-decoration--2"></div>
  <div class="hero-content">
    <h1><span class="highlight">97 choses</span> que tout programmeur agentique devrait savoir</h1>
    <p>{{ t.home.heroSubtitle }}</p>
  </div>
</section>

<section class="book-intro">
  <div class="book-intro-content">
    <p>{{ t.home.introP1 }}</p>
    <p>{{ t.home.introP2 }}</p>
  </div>
</section>

<section class="parts-section">
  <h2>{{ t.home.theEssays }}</h2>

  {% set partKeys = ["working-with-agents", "prompting-as-engineering", "building-agentic-systems", "agents-in-the-real-world", "mindset", "developer-as-user"] %}
  {% set langPosts = collections.posts | filterByLang("fr") %}

  <div class="parts-grid">
    {% for key in partKeys %}
    <div class="part-card">
      <h3 class="part-card-title">{{ t.parts[key].title }}</h3>
      <p class="part-card-desc">{{ t.parts[key].desc }}</p>
      <ul class="part-card-articles">
        {% for post in langPosts %}
          {% if post.data.tags and (key in post.data.tags) %}
          <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </div>
</section>

{% set techArticles = collections["articles"] | filterByLang("fr") %}
{% if techArticles.length %}
<section class="case-studies-section">
  <h2>{{ t.home.articles }}</h2>
  <p class="case-studies-intro">{{ t.home.articlesIntro }}</p>
  <ul class="post-list">
    {% for post in techArticles | reverse %}
    <li class="fade-in">
      {% include "components/post-card.njk" %}
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}

{% set caseStudies = collections["case-studies"] | filterByLang("fr") %}
{% if caseStudies.length %}
<section class="case-studies-section">
  <h2>{{ t.home.caseStudies }}</h2>
  <p class="case-studies-intro">{{ t.home.caseStudiesIntro }}</p>
  <ul class="post-list">
    {% for post in caseStudies | reverse %}
    <li class="fade-in">
      {% include "components/post-card.njk" %}
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}
