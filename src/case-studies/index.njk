---
layout: base.njk
title: Études de cas
permalink: /case-studies/
lang: fr
eleventyExcludeFromCollections: true
---

<section class="page">
  <header class="page-header">
    <h1 class="page-title">{{ title }}</h1>
  </header>

  <div class="section-intro">
    <p>{{ t.sections.caseStudiesIntroP1 }}</p>
    <p>{{ t.sections.caseStudiesIntroP2 }}</p>
  </div>

  {% set caselist = collections["case-studies"] | filterByLang("fr") %}
  {% if caselist.length %}
  <ul class="post-list">
    {% for post in caselist | reverse %}
    <li>
      {% include "components/post-card.njk" %}
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="no-posts">Aucune étude de cas pour le moment.</p>
  {% endif %}
</section>
