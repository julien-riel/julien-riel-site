---
layout: base.njk
title: Études de cas
description: Systèmes agentiques réels analysés en profondeur
permalink: /case-studies/
lang: fr
eleventyExcludeFromCollections: true
---

<section class="page">
  <header class="page-header">
    <h1 class="page-title">{{ title }}</h1>
    <p class="page-description">{{ description }}</p>
  </header>

  {% set caselist = collections["case-studies"] | filterByLang("fr") %}
  {% if caselist.length %}
  <ul class="post-list">
    {% for post in caselist | reverse %}
    <li>
      {% include "components/post-card.njk" %}
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="no-posts">Aucune étude de cas pour le moment.</p>
  {% endif %}
</section>
