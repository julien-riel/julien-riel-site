{% set siteDesc = metadata.description[currentLang] or metadata.description %}
<!DOCTYPE html>
<html lang="{{ currentLang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}{{ metadata.title }}</title>
  <meta name="description" content="{{ description or siteDesc }}">
  <meta name="author" content="{{ metadata.author.name }}">

  {# Open Graph #}
  <meta property="og:title" content="{{ title or metadata.title }}">
  <meta property="og:description" content="{{ description or siteDesc }}">
  <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:locale" content="{{ currentLang }}">
  <meta property="og:site_name" content="{{ metadata.title }}">
  {% if image %}
  <meta property="og:image" content="{{ metadata.url }}{{ image }}">
  {% endif %}

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or metadata.title }}">
  <meta name="twitter:description" content="{{ description or siteDesc }}">
  {% if image %}
  <meta name="twitter:image" content="{{ metadata.url }}{{ image }}">
  {% endif %}

  {# Canonical URL #}
  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">

  {# hreflang alternates — tells Google which URL to serve per locale.
     Skipped for pages without a translated counterpart (tags are shared). #}
  {% if "/tags/" not in page.url %}
    {% if currentLang == "en" %}
      {% set frUrl = page.url | replace("/en/", "/") %}
      {% set enUrl = page.url %}
    {% else %}
      {% set frUrl = page.url %}
      {% set enUrl = "/en" + page.url %}
    {% endif %}
    <link rel="alternate" hreflang="fr" href="{{ metadata.url }}{{ frUrl }}">
    <link rel="alternate" hreflang="en" href="{{ metadata.url }}{{ enUrl }}">
    <link rel="alternate" hreflang="x-default" href="{{ metadata.url }}{{ frUrl }}">
  {% endif %}

  {# RSS / Atom feed — absolute URL avoids Vite asset rewriting #}
  <link rel="alternate" type="application/atom+xml" title="{{ metadata.title }} — {% if currentLang == 'en' %}Feed{% else %}Flux{% endif %}" href="{{ metadata.url }}{% if currentLang == 'en' %}/en/feed.xml{% else %}/feed.xml{% endif %}">

  {# Preload critical fonts (self-hosted) — body + display for fast first paint #}
  <link rel="preload" as="font" type="font/woff2" href="/assets/fonts/outfit-400.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/assets/fonts/dm-serif-display-400.woff2" crossorigin>

  {# Styles #}
  <link rel="stylesheet" href="/assets/css/main.css">

  {% include "components/analytics.njk" %}

  {# JSON-LD Structured Data #}
  {% if layout == 'post.njk' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ title | dump | safe }},
    "description": {{ (description or "") | dump | safe }},
    "datePublished": "{{ date | dateFormat('iso') }}",
    "dateModified": "{{ date | dateFormat('iso') }}",
    "author": {
      "@type": "Person",
      "name": "{{ metadata.author.name }}",
      "url": "{{ metadata.url }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ metadata.title }}",
      "url": "{{ metadata.url }}"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ metadata.url }}{{ page.url }}"
    }
    {% if tags %},
    "keywords": {{ tags | dump | safe }}
    {% endif %}
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ metadata.title }}",
    "description": "{{ siteDesc }}",
    "url": "{{ metadata.url }}",
    "author": {
      "@type": "Person",
      "name": "{{ metadata.author.name }}"
    }
  }
  </script>
  {% endif %}
</head>
<body>
  <a href="#main-content" class="skip-link">{{ t.post.skipLink }}</a>

  {% include "components/header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}
  {% include "components/consent-banner.njk" %}

  <script type="module" src="/assets/js/main.js"></script>
</body>
</html>
