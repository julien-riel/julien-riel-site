<header class="site-header" role="banner">
  <nav class="nav-container" aria-label="{{ 'Navigation principale' if currentLang == 'fr' else 'Main navigation' }}">
    <a href="{{ '/' if currentLang == 'fr' else '/en/' }}" class="logo" aria-label="{{ metadata.title }}">{{ metadata.title }}</a>
    <button
      class="nav-toggle"
      aria-label="{{ t.post.openMenu }}"
      aria-expanded="false"
      aria-controls="main-nav"
    >
      <span class="hamburger" aria-hidden="true"></span>
    </button>
    <ul class="nav-menu" id="main-nav" role="menubar">
      <li class="nav-item" role="none">
        <a href="{{ langPrefix }}/posts/" role="menuitem"{% if page.url.includes('/posts/') %} aria-current="page"{% endif %}>{{ t.nav.essays }}</a>
      </li>
      <li class="nav-item" role="none">
        <a href="{{ langPrefix }}/articles/" role="menuitem"{% if page.url.includes('/articles/') %} aria-current="page"{% endif %}>{{ t.nav.articles }}</a>
      </li>
      <li class="nav-item" role="none">
        <a href="{{ langPrefix }}/case-studies/" role="menuitem"{% if page.url.includes('/case-studies/') %} aria-current="page"{% endif %}>{{ t.nav.caseStudies }}</a>
      </li>
      <li class="nav-item" role="none">
        <a href="/tags/" role="menuitem"{% if page.url.includes('/tags/') %} aria-current="page"{% endif %}>{{ t.nav.tags }}</a>
      </li>
      <li class="nav-item" role="none">
        <a href="{{ langPrefix }}/reading-guide/" role="menuitem"{% if page.url.includes('/reading-guide/') %} aria-current="page"{% endif %}>{{ t.nav.readingGuide }}</a>
      </li>
      <li class="nav-item" role="none">
        {% if currentLang == "fr" %}
          <a href="/en{{ page.url }}" class="lang-switch" role="menuitem" aria-label="{{ t.post.langSwitchLabel }}">EN</a>
        {% else %}
          <a href="{{ page.url | replace('/en/', '/') }}" class="lang-switch" role="menuitem" aria-label="{{ t.post.langSwitchLabel }}">FR</a>
        {% endif %}
      </li>
      <li class="nav-item nav-search" role="none">
        {% include "components/search.njk" %}
      </li>
    </ul>
  </nav>
</header>
