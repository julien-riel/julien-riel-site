{#
  Search component
#}
<div class="search-container">
  <form class="search-form" role="search">
    <label for="search-input" class="visually-hidden">{{ t.post.searchLabel }}</label>
    <input
      type="search"
      id="search-input"
      name="q"
      class="search-input"
      placeholder="{{ t.post.search }}"
      autocomplete="off"
    >
    <button type="submit" class="search-button" aria-label="{{ t.post.searchLabel }}">
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
    </button>
  </form>
  <div class="search-results" aria-live="polite" aria-atomic="true"></div>
</div>
