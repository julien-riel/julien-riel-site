{#
  Post card component - language-aware
  Expects: post object, t (translations), currentLang
#}
<article class="post-card">
  <header class="post-card-header">
    <div class="post-card-meta">
      {% if post.url.includes('/case-studies/') %}
        <span class="post-card-badge post-card-badge--case-study">{{ t.nav.caseStudies if t else "Case Study" }}</span>
      {% elif post.url.includes('/articles/') %}
        <span class="post-card-badge post-card-badge--article">Article</span>
      {% elif post.url.includes('/posts/') %}
        <span class="post-card-badge post-card-badge--essay">{{ t.nav.essays if t else "Essay" }}</span>
      {% endif %}
      <span class="post-card-reading-time">{{ post.templateContent | readingTime }} {{ (t.post.minRead if t else "min read") }}</span>
      {% set isEssay = post.url.includes('/posts/') %}
      {% if not isEssay %}
      <time class="post-card-date" datetime="{{ post.date | dateFormat('iso') }}">
        {{ post.date | dateFormat('short', currentLang) }}
      </time>
      {% endif %}
    </div>
    <h2 class="post-card-title">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </h2>
  </header>

  {% if post.data.description %}
  <p class="post-card-description">{{ post.data.description }}</p>
  {% endif %}

  {% if post.data.tags %}
  <footer class="post-card-footer">
    <ul class="post-card-tags">
      {% for tag in post.data.tags %}
      {% if tag != "posts" and tag != "articles" and tag != "case-studies" and tag != "agentic-programming" %}
      <li><a href="/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a></li>
      {% endif %}
      {% endfor %}
    </ul>
  </footer>
  {% endif %}
</article>
