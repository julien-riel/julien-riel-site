---
layout: base.njk
title: Essays
description: 97 Things Every Agentic Programmer Should Know
permalink: /posts/
---

<section class="page">
  <header class="page-header">
    <h1 class="page-title">{{ title }}</h1>
    <p class="page-description">{{ description }}</p>
  </header>

  {# Preface #}
  {% for post in collections.posts %}
    {% if "book" in post.data.tags %}
    <div class="essay-preface">
      <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <p>{{ post.data.description }}</p>
    </div>
    {% endif %}
  {% endfor %}

  {% set partGroups = [
    { tag: "working-with-agents", title: "Part 1 — Working with Agents" },
    { tag: "prompting-as-engineering", title: "Part 2 — Prompting as Engineering" },
    { tag: "building-agentic-systems", title: "Part 3 — Building Agentic Systems" },
    { tag: "agents-in-the-real-world", title: "Part 4 — Agents in the Real World" },
    { tag: "mindset", title: "Part 5 — Mindset" },
    { tag: "developer-as-user", title: "Part 6 — The Developer as User" }
  ] %}

  {% for part in partGroups %}
  <div class="essay-part">
    <h2 class="essay-part-title">{{ part.title }}</h2>
    <ol class="essay-list">
      {% for post in collections.posts %}
        {% if post.data.tags and (part.tag in post.data.tags) %}
        <li>
          <a href="{{ post.url }}" class="essay-link">
            <span class="essay-link-title">{{ post.data.title }}</span>
            {% if post.data.description %}
            <span class="essay-link-desc">{{ post.data.description }}</span>
            {% endif %}
          </a>
        </li>
        {% endif %}
      {% endfor %}
    </ol>
  </div>
  {% endfor %}
</section>
